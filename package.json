{
  "name": "react-native-headless-tour",
  "version": "0.2.0",
  "description": "Headless multi-instance tour/onboarding library for React Native",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.71.0",
    "react-native-svg": ">=13.0.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^12.4.3",
    "@types/react": "^18.2.79",
    "babel-preset-expo": "^11.0.0",
    "jest": "^29.7.0",
    "react": "18.2.0",
    "react-native": "0.73.6",
    "react-native-svg": "^15.15.5",
    "react-test-renderer": "^18.2.0",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5"
  },
  "keywords": [
    "react-native",
    "tour",
    "onboarding",
    "headless",
    "expo"
  ],
  "license": "MIT",
  "author": "Ismael Castillo",
  "repository": {
    "type": "git",
    "url": "https://github.com/cazismael/react-native-headless-tour"
  },
  "homepage": "https://github.com/cazismael/react-native-headless-tour#readme",
  "bugs": {
    "url": "https://github.com/cazismael/react-native-headless-tour/issues"
  }
}
